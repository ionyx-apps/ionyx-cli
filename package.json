{
  "name": "@ionyx-apps/cli",
  "version": "0.1.1",
  "description": "Ionyx Framework CLI - High-performance desktop apps with Rust and WebGPU",
  "main": "index.js",
  "type": "commonjs",
  "bin": {
    "ionyx": "bin/ionyx.js"
  },
  "scripts": {
    "ionyx": "node bin/ionyx.js",
    "dev": "cd ionyx-cli && cargo run --bin ionyx",
    "build": "cd ionyx-cli && cargo build --release",
    "prepack": "npm run build && (copy ionyx-cli\\target\\release\\ionyx.exe bin\\ionyx.exe || cp ionyx-cli/target/release/ionyx bin/ionyx)",
    "test": "node test-framework.js"
  },
  "files": [
    "bin/",
    "ionyx-cli/src/templates/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ionyx",
    "cli",
    "rust",
    "webgpu",
    "desktop",
    "framework",
    "frontend-native",
    "tauri",
    "electron"
  ],
  "author": "Ionyx Apps <info@ionyx.app>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ionyx-apps/ionyx-cli.git"
  },
  "homepage": "https://ionyx.app",
  "bugs": {
    "url": "https://github.com/ionyx-apps/ionyx/issues"
  },
  "engines": {
    "node": ">= 18.0.0"
  },
  "dependencies": {}
}
