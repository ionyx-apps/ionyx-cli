{
  "name": "my-ionyx-app",
  "version": "1.0.0",
  "description": "Vue + TypeScript + Vite application with Ionyx Framework",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "ionyx:dev": "cd src-ionyx && cargo run --bin ionyx-host",
    "ionyx:build": "cd src-ionyx && cargo build --release",
    "ionyx": "npx ionyx",
    "ionyx:dev2": "npx ionyx dev",
    "ionyx:build2": "npx ionyx build",
    "ionyx:run": "npx ionyx run"
  },
  "dependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vue-tsc": "^1.8.0"
  }
}
