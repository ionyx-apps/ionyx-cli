{
  "name": "my-ionyx-app",
  "version": "1.0.0",
  "description": "React + TypeScript + Vite application with Ionyx Framework",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "ionyx:dev": "cd src-ionyx && cargo run --bin ionyx-host",
    "ionyx:build": "cd src-ionyx && cargo build --release",
    "ionyx": "npx ionyx",
    "ionyx:dev2": "npx ionyx dev",
    "ionyx:build2": "npx ionyx build",
    "ionyx:run": "npx ionyx run"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  }
}
