# Exclude development files
.git/
.github/
node_modules/
target/
*.log
.DS_Store

# Exclude source code (embedded in binary)
ionyx-cli/src/
!ionyx-cli/src/templates/

# Exclude examples and tests
ionyx-examples/
test-framework.js

# Ensure bin is included
!bin/
!bin/ionyx.js
!bin/ionyx.exe
!bin/ionyx
